<dots:metadataMap 
  xmlns:dots="https://github.com/chartes/dots/" 
  xmlns:dts="https://dtsapi.org/context/v1.0.json" 
  xmlns:dct="http://purl.org/dc/terms/" 
  xmlns:schema="https://schema.org/" 
  xmlns:html="http://www.w3.org/1999/xhtml" 
  xmlns:dcat="http://www.w3.org/ns/dcat#">
  <dots:mapping>
    <dct:title scope="collection" source="./collection.tsv" value="title"/>
    <dct:creator scope="collection" source="./collection.tsv" value="creator"/>
    <dct:publisher scope="collection" source="./collection.tsv" value="publisher"/>
    <dct:issued scope="collection" source="./collection.tsv" value="issued"/>
    <dct:description scope="collection" source="./collection.tsv" value="description"/>
    <schema:name scope="collection" source="./collection.tsv" value="title"/>
    <schema:author scope="collection" source="./collection.tsv" type="object">
      <dots:objectProperty name="@type" resourceId="all">schema:Person</dots:objectProperty>
      <dots:objectProperty name="@id" value="creator_bnf_ark"/>
      <dots:objectProperty name="name" value="creator"/>
      <dots:objectProperty name="sameAs" value="creator_idref_ppn"/>
    </schema:author>
    <schema:datePublished scope="collection" source="./collection.tsv" value="issued"/>
    <schema:description scope="collection" source="./collection.tsv" value="description"/>
    <dcat:accessURL scope="collection" source="./collection.tsv" value="id" prefix="https://dev.chartes.psl.eu/dots/api/dts/collection?id="/>
    <dct:title scope="document" xpath="/TEI/teiHeader/fileDesc/titleStmt/title[1]"/>
    <dct:creator scope="document" xpath="/TEI/teiHeader/fileDesc/titleStmt/author"/>
    <dct:created scope="document" xpath="/TEI/teiHeader/profileDesc/creation/date[not(@type)]"/>
    <dct:language scope="document" xpath="/TEI/teiHeader/profileDesc/langUsage/language/tokenize(@ident)"/>
    <dct:contributor scope="document" xpath="/TEI/teiHeader/fileDesc/titleStmt/principal | /TEI/teiHeader/fileDesc/titleStmt/editor"/>
    <dct:source scope="document" xpath="for $ms in /TEI/teiHeader/fileDesc/sourceDesc/msDesc/msIdentifier return concat($ms/settlement, ', ', $ms/repository, ', ', $ms/idno)"/>
    <dct:publisher scope="document" xpath="/TEI/teiHeader/fileDesc/publicationStmt/publisher"/>
    <dct:issued scope="document" xpath="/TEI/teiHeader/fileDesc/publicationStmt/date"/>
    <dct:description scope="document" xpath="/TEI/teiHeader/encodingDesc/projectDesc/p"/>
    <dct:license scope="document" xpath="/TEI/teiHeader/fileDesc/publicationStmt/availability/licence/@target"/>
    <dct:rights scope="document" xpath="/TEI/teiHeader/fileDesc/publicationStmt/availability/licence"/>
    <dct:identifier scope="document" xpath="/TEI/teiHeader/fileDesc/publicationStmt/idno"/>
    <schema:type scope="document" resourceId="all">Book</schema:type>
    <schema:name scope="document" xpath="/TEI/teiHeader/fileDesc/titleStmt/title[1]"/>
    <schema:author scope="document" xpath="/TEI/teiHeader/fileDesc/titleStmt/author[@ref]" type="object">
      <dots:objectProperty name="@type" resourceId="all">schema:Person</dots:objectProperty>
      <dots:objectProperty name="@id" xpath="let $refs := tokenize(@ref) return $refs[1]"/>
      <dots:objectProperty name="name" xpath="."/>
      <dots:objectProperty name="sameAs" xpath="subsequence(tokenize(@ref), 2)"/>
    </schema:author>
    <schema:dateCreated scope="document" xpath="/TEI/teiHeader/profileDesc/creation/date[not(@type)]"/>
    <schema:inLanguage scope="document" xpath="/TEI/teiHeader/profileDesc/langUsage/language/tokenize(@ident)"/>
    <schema:editor scope="document" xpath="/TEI/teiHeader/fileDesc/titleStmt/editor | /TEI/teiHeader/fileDesc/titleStmt/principal" type="object">
      <dots:objectProperty name="@type" resourceId="all">schema:Person</dots:objectProperty>
      <dots:objectProperty name="@id" xpath="let $refs := tokenize(@ref) return $refs[1]"/>
      <dots:objectProperty name="name" xpath="."/>
      <dots:objectProperty name="sameAs" xpath="subsequence(tokenize(@ref), 2)"/>
    </schema:editor>
    <schema:isBasedOn scope="document" xpath="/TEI/teiHeader/fileDesc/sourceDesc/msDesc" type="object">
      <dots:objectProperty name="@type" resourceId="all">schema:CreativeWork</dots:objectProperty>
      <dots:objectProperty name="@id" xpath="let $sources := tokenize(@source) return $sources[1]"/>
      <dots:objectProperty name="name" xpath="concat(./msIdentifier/settlement, ', ', ./msIdentifier/repository, ', ', ./msIdentifier/idno)"/>
      <dots:objectProperty name="sameAs" xpath="subsequence(tokenize(@source), 2)"/>
    </schema:isBasedOn>
    <schema:publisher scope="document" xpath="/TEI/teiHeader/fileDesc/publicationStmt/publisher" type="object">
      <dots:objectProperty name="@type" resourceId="all">schema:Organization</dots:objectProperty>
      <dots:objectProperty name="@id" xpath="./@ref"/>
      <dots:objectProperty name="name" xpath="."/>
    </schema:publisher>
    <schema:datePublished scope="document" xpath="/TEI/teiHeader/fileDesc/publicationStmt/date"/>
    <schema:description scope="document" xpath="/TEI/teiHeader/encodingDesc/projectDesc/p"/>
    <schema:license scope="document" xpath="/TEI/teiHeader/fileDesc/publicationStmt/availability/licence/@target"/>
    <schema:encoding scope="document" xpath="/TEI/@xml:id" type="object">
      <dots:objectProperty name="@type" resourceId="all">schema:MediaObject</dots:objectProperty>
      <dots:objectProperty name="encodingFormat" resourceId="all">application/tei+xml</dots:objectProperty>
      <dots:objectProperty name="contentUrl" xpath="concat('https://dev.chartes.psl.eu/dots/api/dts/document?resource=', .)"/>
    </schema:encoding>
    <schema:encoding scope="document" xpath="/TEI/@xml:id" type="object">
      <dots:objectProperty name="@type" resourceId="all">schema:MediaObject</dots:objectProperty>
      <dots:objectProperty name="encodingFormat" resourceId="all">text/html</dots:objectProperty>
      <dots:objectProperty name="contentUrl" xpath="concat('https://dev.chartes.psl.eu/dots/api/dts/document?resource=', ., codepoints-to-string(38), 'mediaType=html')"/>
    </schema:encoding>
    <download xmlns="http://www.tei-c.org/ns/1.0" scope="document" xpath="let $id := /TEI/@xml:id return concat('api/dts/document?resource=', $id)" prefix="https://dev.chartes.psl.eu/dots/"/>
    <dots:shortTitle scope="document" xpath="/TEI/teiHeader/fileDesc/titleStmt/title[@type='short']"/>
    <dcat:accessURL scope="document" xpath="/TEI/@xml:id" prefix="https://dev.chartes.psl.eu/dots/api/dts/collection?id="/>
  </dots:mapping>
</dots:metadataMap>